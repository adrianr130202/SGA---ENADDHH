---
import { getLinks } from './utils.js';
const currentPath = Astro.url.pathname;
const links = getLinks(currentPath);
---
<header class="sticky top-0 z-50 w-full bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 shadow-sm transition-colors duration-300">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-5 gap-4">
    
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img
        src="/logo escuela.png"
        alt="Logo ENADDHH"
        class="h-9 w-auto object-contain"
      />
      <div class="flex flex-col leading-tight">
        <span class="text-xs font-bold text-slate-800 dark:text-slate-100 tracking-widest uppercase">ENADDHH</span>
        <span class="text-[10px] text-slate-400 dark:text-slate-400 font-medium hidden sm:block">Sistema de Gestión Académica</span>
      </div>
    </a>
 
    <div class="hidden md:flex items-center gap-4">
      <nav id="action-container" class="flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.to}
            aria-current={currentPath === link.to ? "page" : undefined}
            class={`text-[13px] font-medium px-3 py-1.5 rounded-lg transition-colors ${
              currentPath === link.to
                ? 'text-blue-900 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 font-semibold'
                : 'text-slate-500 dark:text-slate-300 hover:text-slate-800 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            {link.name}
          </a>
        ))}
      </nav>

      <div class="h-5 w-px bg-slate-200 dark:bg-slate-600"></div>

      <button aria-label="Cambiar tema" class="btn-theme-toggle p-2 rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors focus:outline-none flex items-center justify-center">
        <span class="theme-icon text-sm flex items-center justify-center">
          </span>
      </button>
    </div>

    <div class="flex md:hidden items-center gap-2">
      <button aria-label="Cambiar tema" class="btn-theme-toggle p-1.5 rounded-lg text-slate-500 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors focus:outline-none flex items-center justify-center">
        <span class="theme-icon text-sm flex items-center justify-center">
          </span>
      </button>
      
      <button id="mobile-menu-open" aria-label="Abrir menú de navegación" class="p-1.5 rounded-lg text-slate-500 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors focus:outline-none">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</header>
 
<div id="mobile-sidebar-container" class="fixed inset-0 z-50 hidden">
 
  <div
    id="mobile-sidebar-backdrop"
    class="fixed inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm transition-opacity opacity-0"
  ></div>
 
  <aside
    id="mobile-sidebar"
    class="fixed right-0 top-0 h-full w-64 translate-x-full transform bg-white dark:bg-slate-800 p-6 shadow-xl transition-transform duration-300 ease-in-out border-l border-slate-200 dark:border-slate-700"
  >
    <div class="flex items-center justify-between mb-6 pb-5 border-b border-slate-100 dark:border-slate-700">
      <div class="flex items-center gap-2.5">
        <img
          src="/logo escuela.png"
          alt="Logo ENADDHH"
          class="h-8 w-auto object-contain"
        />
        <span class="text-sm font-bold text-slate-800 dark:text-slate-100 tracking-wide">ENADDHH</span>
      </div>
 
      <button
        id="mobile-menu-close"
        class="p-1.5 rounded-lg text-slate-400 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        aria-label="Cerrar menú"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
 
    <nav class="flex flex-col gap-1 mb-6">
      {links.map((link) => (
        <a
          href={link.to}
          aria-current={currentPath === link.to ? "page" : undefined}
          class={`flex items-center px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${
            currentPath === link.to
              ? 'text-blue-900 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 font-semibold'
              : 'text-slate-600 dark:text-slate-300 hover:text-slate-800 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-700'
          }`}
        >
          {link.name}
        </a>
      ))}
    </nav>
 
    <div class="h-px bg-slate-100 dark:bg-slate-700 mb-5"></div>
 
    <div class="flex flex-col gap-3">
      <a
        href="/login"
        class="w-full text-center text-[13px] font-semibold text-slate-700 dark:text-slate-200 border border-slate-200 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 px-4 py-2.5 rounded-lg transition-colors"
      >
        Iniciar sesión
      </a>
      <a
        href="/signup"
        class="w-full text-center text-[13px] font-bold text-white bg-blue-900 dark:bg-blue-600 hover:bg-blue-800 dark:hover:bg-blue-500 px-4 py-2.5 rounded-lg transition-colors shadow-sm"
      >
        Registrarse
      </a>
    </div>
  </aside>
</div>

<script is:inline>
  // LÓGICA DEL MODO OSCURO
  const themeToggles = document.querySelectorAll('.btn-theme-toggle');
  
  const updateThemeIcons = (isDark) => {
    const moonIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>';
    const sunIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>';
    
    document.querySelectorAll('.theme-icon').forEach(icon => {
      icon.innerHTML = isDark ? moonIcon : sunIcon;
    });
  };

  const isDarkInit = document.documentElement.classList.contains('dark');
  updateThemeIcons(isDarkInit);

  themeToggles.forEach(btn => {
    btn.addEventListener('click', () => {
      const isDarkNow = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDarkNow ? 'dark' : 'light');
      updateThemeIcons(isDarkNow);
    });
  });

  // LÓGICA DEL MENÚ MÓVIL
  const mobileContainer = document.getElementById('mobile-sidebar-container');
  const mobileBackdrop = document.getElementById('mobile-sidebar-backdrop');
  const mobileSidebar = document.getElementById('mobile-sidebar');
  const btnClose = document.getElementById('mobile-menu-close');
  const btnOpen = document.getElementById('mobile-menu-open');

  const openMenu = () => {
    if(!mobileContainer) return;
    mobileContainer.classList.remove('hidden');
    // Pequeño timeout para permitir que la animación fluya
    setTimeout(() => {
      mobileBackdrop.classList.remove('opacity-0');
      mobileSidebar.classList.remove('translate-x-full');
    }, 10);
  };

  const closeMenu = () => {
    if(!mobileContainer) return;
    mobileBackdrop.classList.add('opacity-0');
    mobileSidebar.classList.add('translate-x-full');
    setTimeout(() => {
      mobileContainer.classList.add('hidden');
    }, 300); // 300ms para que termine la animación
  };

  if(btnOpen) btnOpen.addEventListener('click', openMenu);
  if(btnClose) btnClose.addEventListener('click', closeMenu);
  if(mobileBackdrop) mobileBackdrop.addEventListener('click', closeMenu);

  //  CERRAR MENÚ CON LA TECLA ESCAPE
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileContainer && !mobileContainer.classList.contains('hidden')) {
      closeMenu();
    }
  });
</script>