---
const { activePage } = Astro.props;
---

<div class="md:hidden flex items-center justify-between px-5 py-3 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 w-full shrink-0 transition-colors duration-300 z-30">
  <div class="flex items-center gap-3">
    <div class="bg-blue-900 dark:bg-blue-600 text-white w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm shadow-sm transition-colors">S</div>
    <span class="font-bold text-slate-800 dark:text-slate-100 tracking-wide text-sm">SGA - ENADDHH</span>
  </div>
  
  <div class="flex items-center gap-2">
    <button aria-label="Cambiar tema visual" class="btn-theme-toggle p-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors focus:outline-none flex items-center justify-center">
      <span class="theme-icon flex items-center justify-center">
        </span>
    </button>
    <button id="btn-open-sidebar" aria-label="Abrir menú lateral" class="p-1.5 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</div>

<div id="sidebar-backdrop" aria-hidden="true" class="fixed inset-0 bg-slate-900/60 dark:bg-black/80 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300 md:hidden"></div>

<aside id="sidebar-menu" class="fixed md:static inset-y-0 left-0 z-50 h-full w-64 bg-white dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 flex flex-col shrink-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out shadow-2xl md:shadow-none">

  <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100 dark:border-slate-700 shrink-0">
    <div class="flex items-center gap-3">
      <div class="bg-blue-900 dark:bg-blue-600 text-white w-9 h-9 rounded-xl flex items-center justify-center font-bold text-base shadow-sm shrink-0 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
        </svg>
      </div>
      <div>
        <p class="font-bold text-slate-800 dark:text-slate-100 text-sm leading-tight tracking-wide">SGA</p>
        <p class="text-[10px] text-slate-400 dark:text-slate-500 font-medium">ENADDHH</p>
      </div>
    </div>

    <button id="btn-close-sidebar" aria-label="Cerrar menú lateral" class="md:hidden p-1.5 rounded-lg text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-slate-700 transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <nav aria-label="Navegación principal" class="flex-1 px-3 py-5 overflow-y-auto">
    <p class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-3 mb-3">Principal</p>
    <ul class="space-y-1">

      <li>
        <a href="/dashboard" aria-current={activePage === 'dashboard' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'dashboard' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
          Panel Principal
        </a>
      </li>

      <li>
        <a href="/courses" aria-current={activePage === 'courses' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'courses' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Diplomados
        </a>
      </li>

      <li>
        <a href="/students" aria-current={activePage === 'students' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'students' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          Estudiantes
        </a>
      </li>

      <li>
        <a href="/enrollments" aria-current={activePage === 'enrollments' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'enrollments' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Inscripciones
        </a>
      </li>

      <li>
        <a href="/grades" aria-current={activePage === 'grades' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'grades' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Calificaciones
        </a>
      </li>

      <li>
        <a href="/certificates" aria-current={activePage === 'certificates' ? 'page' : undefined} class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-colors ${activePage === 'certificates' ? 'bg-blue-50 text-blue-900 dark:bg-blue-900/30 dark:text-blue-400' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
          Certificados
        </a>
      </li>

    </ul>
  </nav>

  <div class="px-4 py-4 border-t border-slate-100 dark:border-slate-700 space-y-1 shrink-0">
    
    <button aria-label="Cambiar tema visual principal" class="btn-theme-toggle hidden md:flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-[13px] font-medium text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-slate-800 dark:hover:text-slate-200 transition-colors">
      <span class="theme-icon shrink-0 flex items-center justify-center">
        </span>
      <span class="theme-text">Modo Claro</span>
    </button>

    <button
      onclick="document.cookie = 'token_sga=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;'; window.location.href='/';"
      class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-[13px] font-medium text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 hover:text-red-700 dark:hover:text-red-300 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Cerrar Sesión
    </button>
  </div>
</aside>

<script is:inline>
  //  LÓGICA MODO OSCURO GLOBAL 
  const themeToggles = document.querySelectorAll('.btn-theme-toggle');
  
  const updateThemeUI = (isDark) => {
    const moonIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>';
    const sunIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>';

    document.querySelectorAll('.theme-icon').forEach(icon => {
      icon.innerHTML = isDark ? moonIcon : sunIcon;
    });
    document.querySelectorAll('.theme-text').forEach(text => {
      text.textContent = isDark ? 'Modo Oscuro' : 'Modo Claro';
    });
  };

  const isDarkMode = document.documentElement.classList.contains('dark');
  updateThemeUI(isDarkMode);

  themeToggles.forEach(btn => {
    btn.addEventListener('click', () => {
      const isDarkNow = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDarkNow ? 'dark' : 'light');
      updateThemeUI(isDarkNow);
    });
  });

  // LÓGICA MENÚ DEL MÓVIL
  const btnOpen = document.getElementById('btn-open-sidebar');
  const btnClose = document.getElementById('btn-close-sidebar');
  const sidebar = document.getElementById('sidebar-menu');
  const backdrop = document.getElementById('sidebar-backdrop');

  const openSidebar = () => {
    backdrop.classList.remove('hidden');
    // Mini-pausa para que Tailwind procese la animación de opacidad
    setTimeout(() => backdrop.classList.remove('opacity-0'), 10);
    sidebar.classList.remove('-translate-x-full');
  };

  const closeSidebar = () => {
    backdrop.classList.add('opacity-0');
    sidebar.classList.add('-translate-x-full');
    // Esperamos 300ms (lo que dura la transición) antes de ocular el div
    setTimeout(() => backdrop.classList.add('hidden'), 300);
  };

  if (btnOpen) btnOpen.addEventListener('click', openSidebar);
  if (btnClose) btnClose.addEventListener('click', closeSidebar);
  if (backdrop) backdrop.addEventListener('click', closeSidebar);

  // --- 3. CERRAR MENÚ CON LA TECLA ESCAPE ---
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && backdrop && !backdrop.classList.contains('hidden')) {
      closeSidebar();
    }
  });
</script>