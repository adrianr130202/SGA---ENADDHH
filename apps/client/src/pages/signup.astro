---
import PageLayout from '../Layout/PageLayout.astro';

// También deberías proteger esta ruta si el usuario ya está logueado
const tokenCookie = Astro.cookies.get('token_sga');
if (tokenCookie) {
  return Astro.redirect('/dashboard');
}
---
 
<PageLayout title="Registro - SGA">
 
  <main class="flex items-center justify-center h-[calc(100vh-65px)] bg-slate-100 dark:bg-slate-900 overflow-hidden transition-colors duration-300">
    
    <div class="w-full max-w-[400px] mx-4 flex flex-col items-center">
 
      <div class="flex flex-col items-center mb-4 shrink-0">
        <div 
          class="w-14 h-14 bg-blue-900 dark:bg-blue-600 rounded-2xl flex items-center justify-center shadow-lg mb-2 transition-colors"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 14l9-5-9-5-9 5 9 5z"/>
            <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
          </svg>
        </div>
        <h1 class="text-sm font-bold text-slate-800 dark:text-slate-100 tracking-widest uppercase transition-colors">ENADDHH</h1>
        <p class="text-[11px] text-slate-400 dark:text-slate-400 font-medium tracking-wide transition-colors">Sistema de Gestión Académica</p>
      </div>
 
      <section class="w-full shrink-0 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-sm p-6 sm:p-8 transition-colors duration-300">
 
        <div class="mb-5">
          <h2 class="text-base font-bold text-slate-800 dark:text-slate-100 transition-colors">Crear cuenta</h2>
          <p class="text-xs text-slate-400 dark:text-slate-400 mt-0.5 transition-colors">Registro de nuevo administrador del sistema</p>
        </div>
 
        <form id="signup-form" class="flex flex-col gap-4">
 
          <div>
            <label for="email" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1.5 uppercase tracking-wide transition-colors">
              Correo electrónico
            </label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="tu@correo.com"
              required
              class="w-full border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2.5 text-sm text-slate-700 dark:text-white bg-slate-50 dark:bg-slate-700 outline-none focus:border-blue-900 dark:focus:border-blue-500 focus:ring-2 focus:ring-blue-900/10 dark:focus:ring-blue-500/20 transition-all placeholder-slate-300 dark:placeholder-slate-500"
            />
          </div>
 
          <div>
            <label for="password" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1.5 uppercase tracking-wide transition-colors">
              Contraseña
            </label>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="new-password"
              placeholder="••••••••"
              required
              minlength="8"
              class="w-full border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2.5 text-sm text-slate-700 dark:text-white bg-slate-50 dark:bg-slate-700 outline-none focus:border-blue-900 dark:focus:border-blue-500 focus:ring-2 focus:ring-blue-900/10 dark:focus:ring-blue-500/20 transition-all"
            />
            <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-1.5 transition-colors">Mínimo 8 caracteres con letras y números</p>
          </div>
 
          <p id="error-msg" aria-live="assertive" class="hidden text-xs text-red-600 dark:text-red-400 font-medium bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-900 rounded-lg px-3 py-2 text-center transition-colors"></p>
 
          <button
            type="submit"
            class="flex justify-center items-center gap-4 w-full mt-1 bg-blue-900 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-500 active:scale-[0.98] text-white text-sm font-bold py-2.5 px-4 rounded-lg transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-800 disabled:opacity-70 disabled:cursor-not-allowed"
          >
            Crear cuenta
          </button>
 
        </form>
 
        <p class="text-center text-xs text-slate-400 dark:text-slate-400 mt-5 transition-colors">
          ¿Ya tienes cuenta?
          <a href="/login" class="text-blue-900 dark:text-blue-400 font-semibold hover:underline transition-colors ml-1 focus:outline-none focus:ring-1 focus:ring-blue-500 rounded px-1">
            Inicia sesión
          </a>
        </p>
      </section>
 
      <footer class="mt-4 shrink-0">
        <p class="text-center text-[10px] text-slate-300 dark:text-slate-500 transition-colors">
          © 2026 Escuela Nacional de los Derechos Humanos
        </p>
      </footer>
    </div>
  </main>
</PageLayout>
 
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('signup-form');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const errorMsg = document.getElementById('error-msg');
    const submitBtn = form?.querySelector('button[type="submit"]');
 
    if (form && submitBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
 
        errorMsg.classList.add('hidden');
        submitBtn.textContent = 'Registrando...';
        submitBtn.disabled = true;
 
        try {
          const response = await fetch('https://sga-backend-api.onrender.com/api/user', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: emailInput.value,
              password: passwordInput.value
            })
          });
 
          const data = await response.json();
 
          if (response.ok) {
            alert('¡Administrador registrado con éxito! Por favor, inicia sesión.');
            window.location.href = '/login'; // Cambiado a /login para que la UX sea directa
          } else {
            errorMsg.textContent = data.error || data.errores?.join(', ') || 'Error al registrar la cuenta';
            errorMsg.classList.remove('hidden');
          }
        } catch (error) {
          errorMsg.textContent = 'El servidor backend está apagado o no responde.';
          errorMsg.classList.remove('hidden');
        } finally {
          submitBtn.textContent = 'Crear cuenta';
          submitBtn.disabled = false;
        }
      });
    }
  });
</script>