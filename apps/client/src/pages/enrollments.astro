---
import DashboardLayout from '../Layout/DashboardLayout.astro';

const tokenCookie = Astro.cookies.get('token_sga');

if (!tokenCookie) {
  return Astro.redirect('/');
}

// ============================================================================
// 2. DEFINICIÓN DE TIPOS (TypeScript)
// Define la estructura exacta de los datos esperados de la API
// ============================================================================
interface Inscripcion {
  enrollmentId: number | string;
  createdAt: string;
  fullName: string;
  cedula: string;
  courseName: string;
  status: 'cursando' | 'congelado' | 'retirado' | 'finalizado';
}

// Estado inicial
let inscripciones: Inscripcion[] = [];
let correoUsuario = "Administrador";

//
// Obtención de datos
try {
  // Decodificación segura del JWT para obtener los datos del usuario logueado
  const payloadBase64 = tokenCookie.value.split('.')[1];
  const payloadDecodificado = Buffer.from(payloadBase64, 'base64').toString('utf-8');
  correoUsuario = JSON.parse(payloadDecodificado).email;

  // Petición al backend usando el token de autorización
  const response = await fetch('https://sga-enaddhh.onrender.com/api/enrollments', {
    method: 'GET',
    headers: {
      'Authorization': `Bearer ${tokenCookie.value}`
    }
  });

  if (response.ok) {
    inscripciones = await response.json();
  } else {
    console.warn(`La API respondió con estado: ${response.status}`);
  }
} catch (error) {
  console.error("Error crítico al cargar el historial de inscripciones:", error);
}



/**
 * Mapea el estado académico a clases de Tailwind (modo claro y oscuro)
 */
const STATUS_COLORS: Record<string, string> = {
  cursando:   'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 border border-transparent dark:border-blue-800/50',
  congelado:  'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400 border border-transparent dark:border-yellow-800/50',
  retirado:   'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border border-transparent dark:border-red-800/50',
  finalizado: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border border-transparent dark:border-green-800/50',
  default:    'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300 border border-transparent dark:border-gray-700'
};

/**
 * Mapea el estado académico a su ícono representativo
 */
const STATUS_ICONS: Record<string, string> = {
  cursando:   '▶',
  congelado:  '⏸',
  retirado:   '✕',
  finalizado: '✓',
  default:    '•'
};

// Funciones de acceso rápido para la vista
const getStatusColor = (status: string) => STATUS_COLORS[status.toLowerCase()] || STATUS_COLORS.default;
const getStatusIcon = (status: string) => STATUS_ICONS[status.toLowerCase()] || STATUS_ICONS.default;
---

<DashboardLayout title="Historial de Inscripciones" activePage="enrollments">

  <header class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-10 px-6 h-14 flex items-center justify-between shrink-0 transition-colors duration-300">      
    <div class="mr-auto">
      <h1 class="text-sm font-semibold text-slate-800 dark:text-slate-100 leading-tight">Control de Inscripciones</h1>
      <p class="text-[11px] text-slate-400 dark:text-slate-400 leading-tight">Bitácora general y gestión de estados académicos</p>
    </div>

    {inscripciones.length > 0 && (
      <span class="text-xs text-slate-500 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 px-2.5 py-1 rounded-full font-medium transition-colors">
        {inscripciones.length} registro{inscripciones.length !== 1 ? 's' : ''}
      </span>
    )}
  </header>

  <main class="flex-1 p-6 flex flex-col gap-5 overflow-y-auto">

    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm overflow-hidden transition-colors duration-300">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">

          <thead class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700">
            <tr class="text-[11px] font-semibold text-slate-500 dark:text-slate-300 uppercase tracking-wider">
              <th class="px-5 py-3">Fecha</th>
              <th class="px-5 py-3">Estudiante</th>
              <th class="px-5 py-3">Diplomado</th>
              <th class="px-5 py-3 text-center">Estado</th>
              <th class="px-5 py-3 text-center">Acción</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
            {inscripciones.length === 0 ? (
              <tr>
                <td colspan="5" class="py-20 text-center">
                  <div class="flex flex-col items-center text-slate-300 dark:text-slate-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <p class="text-sm font-medium text-slate-400 dark:text-slate-400">No hay registros de inscripciones</p>
                    <p class="text-xs text-slate-300 dark:text-slate-500 mt-1">Las nuevas inscripciones aparecerán aquí</p>
                  </div>
                </td>
              </tr>
            ) : (
              inscripciones.map((ins) => (
                <tr class="hover:bg-slate-50/80 dark:hover:bg-slate-700/50 transition-colors">

                  <td class="px-5 py-3.5">
                    <p class="text-xs font-medium text-slate-600 dark:text-slate-300">
                      {new Date(ins.createdAt).toLocaleDateString('es-VE')}
                    </p>
                    <p class="text-[10px] text-slate-400 dark:text-slate-500">
                      {new Date(ins.createdAt).toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'})}
                    </p>
                  </td>

                  <td class="px-5 py-3.5">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-full bg-blue-900 dark:bg-blue-600 text-white flex items-center justify-center text-[10px] font-bold shrink-0">
                        {ins.fullName.split(' ').map((n: string) => n[0]).join('').slice(0,2).toUpperCase()}
                      </div>
                      <div>
                        <p class="font-semibold text-slate-800 dark:text-slate-100 text-sm leading-tight">{ins.fullName}</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500">V-{ins.cedula}</p>
                      </div>
                    </div>
                  </td>

                  <td class="px-5 py-3.5">
                    <p class="text-slate-700 dark:text-slate-200 font-medium text-sm">{ins.courseName}</p>
                  </td>

                  <td class="px-5 py-3.5 text-center">
                    <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold capitalize ${getStatusColor(ins.status)}`}>
                      {getStatusIcon(ins.status)}
                      {ins.status}
                    </span>
                  </td>

                  <td class="px-5 py-3.5 text-center">
                    <button
                      class="btn-cambiar-estado flex items-center gap-1.5 text-xs font-medium text-blue-900 dark:text-blue-400 hover:text-blue-700 hover:bg-blue-50 dark:hover:bg-slate-700 px-2.5 py-1.5 rounded-lg border border-blue-200 dark:border-blue-800/50 hover:border-blue-300 dark:hover:border-blue-600 transition-colors mx-auto"
                      data-id={ins.enrollmentId}
                      data-nombre={ins.fullName}
                      data-estado={ins.status}
                      aria-label={`Cambiar estado de ${ins.fullName}`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      Cambiar Estado
                    </button>
                  </td>

                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      {inscripciones.length > 0 && (
        <div class="px-5 py-3 border-t border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 transition-colors duration-300">
          <p class="text-xs text-slate-400 dark:text-slate-400">
            Total: <span class="font-semibold text-slate-600 dark:text-slate-300">{inscripciones.length}</span> inscripción{inscripciones.length !== 1 ? 'es' : ''}
          </p>
        </div>
      )}
    </div>

    <p class="text-[11px] text-center text-slate-300 dark:text-slate-500">
      © {new Date().getFullYear()} Sistema de Gestión Académica — Escuela Nacional de los Derechos Humanos
    </p>

    <div id="modal-estado" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 items-center justify-center p-4" aria-modal="true" role="dialog">
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transition-colors duration-300">

        <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex items-center justify-between">
          <div>
            <h2 class="text-base font-bold text-slate-800 dark:text-white">Modificar Estado</h2>
            <p id="estudiante-nombre" class="text-xs text-slate-400 dark:text-slate-400 mt-0.5 font-medium"></p>
          </div>
          <button type="button" id="btn-cerrar-modal" class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-slate-700 transition-colors text-lg font-bold" aria-label="Cerrar modal">
            &times;
          </button>
        </div>

        <form id="form-estado" class="px-6 py-5 space-y-4">
          <input type="hidden" id="inscripcion-id">

          <div>
            <label for="select-nuevo-estado" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1.5 uppercase tracking-wide">
              Nueva condición académica
            </label>
            <select
              id="select-nuevo-estado" required
              class="w-full border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2.5 text-sm text-slate-700 dark:text-white bg-slate-50 dark:bg-slate-700 outline-none focus:border-blue-900 dark:focus:border-blue-500 focus:ring-2 focus:ring-blue-900/10 transition cursor-pointer"
            >
              <option value="cursando">Cursando (Activo)</option>
              <option value="congelado">Congelado (Pausado)</option>
              <option value="retirado">Retirado (Baja)</option>
            </select>
          </div>

          <p id="estado-error" class="hidden text-red-600 dark:text-red-400 text-xs font-medium bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg px-3 py-2"></p>

          <button
            type="submit"
            class="w-full bg-blue-900 dark:bg-blue-600 hover:bg-blue-800 dark:hover:bg-blue-500 active:scale-[0.98] text-white py-2.5 rounded-lg text-sm font-bold transition-all shadow-sm"
          >
            Actualizar Registro
          </button>
        </form>
      </div>
    </div>

  </main>
</DashboardLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Utilidad para leer cookies de forma segura
    const getCookie = (name) => {
      const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    };
    
    const token = getCookie('token_sga');
    
    // Referencias al DOM 
    const modalEstado = document.getElementById('modal-estado');
    const formEstado = document.getElementById('form-estado');
    const msgError = document.getElementById('estado-error');
    const inputId = document.getElementById('inscripcion-id');
    const inputNombre = document.getElementById('estudiante-nombre');
    const selectEstado = document.getElementById('select-nuevo-estado');

   
    const cerrarModal = () => {
      modalEstado.classList.add('hidden');
      modalEstado.classList.remove('flex');
      msgError.classList.add('hidden'); 
    };

    document.getElementById('btn-cerrar-modal').addEventListener('click', cerrarModal);

    // Asignar eventos a todos los botones de estado
    document.querySelectorAll('.btn-cambiar-estado').forEach(boton => {
      boton.addEventListener('click', () => {
        
        inputId.value = boton.dataset.id;
        inputNombre.textContent = `Estudiante: ${boton.dataset.nombre}`;
        selectEstado.value = boton.dataset.estado;
        
        modalEstado.classList.remove('hidden');
        modalEstado.classList.add('flex');
      });
    });

    // Procesamiento del formulario 
    formEstado.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const id = inputId.value;
      const status = selectEstado.value;

      try {
        // Deshabilitar botón para prevenir doble envío
        const btnSubmit = formEstado.querySelector('button[type="submit"]');
        btnSubmit.disabled = true;
        btnSubmit.textContent = 'Actualizando...';

        const res = await fetch(`https://sga-enaddhh.onrender.com/api/enrollments/${id}/status`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json', 
            'Authorization': `Bearer ${token}` 
          },
          body: JSON.stringify({ status })
        });
        
        if (res.ok) {
          window.location.reload(); // Recargar para reflejar cambios en la tabla
        } else {
          throw new Error('Error en la respuesta del servidor');
        }
      } catch (err) {
        msgError.textContent = 'No se pudo actualizar. Verifique su conexión.';
        msgError.classList.remove('hidden');
      } finally {
        // Restaurar botón en caso de error
        const btnSubmit = formEstado.querySelector('button[type="submit"]');
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Actualizar Registro';
      }
    });
  });
</script>