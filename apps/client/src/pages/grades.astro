---
import DashboardLayout from '../Layout/DashboardLayout.astro';


const tokenCookie = Astro.cookies.get('token_sga');

if (!tokenCookie) {
  return Astro.redirect('/');
}

//  Definicion de tipos
interface Curso {
  id: number;
  name: string;
}

let diplomados: Curso[] = [];
let correoUsuario = "Administrador";

//  OBTENCIÓN DE DATOS INICIALES (Diplomados disponibles)
try {
  // Decodificación del token JWT
  const payloadBase64 = tokenCookie.value.split('.')[1];
  const payloadDecodificado = Buffer.from(payloadBase64, 'base64').toString('utf-8');
  correoUsuario = JSON.parse(payloadDecodificado).email;

  const response = await fetch('http://localhost:3000/api/courses', {
    method: 'GET',
    headers: { 'Authorization': `Bearer ${tokenCookie.value}` }
  });

  if (response.ok) {
    diplomados = await response.json();
  } else {
    console.warn(`Falla al cargar diplomados: Código HTTP ${response.status}`);
  }
} catch (error) {
  console.error("Error crítico al cargar los diplomados para calificaciones:", error);
}
---

<DashboardLayout title="Gestión de Calificaciones" activePage="grades">

  <header class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-10 px-6 h-14 flex items-center justify-between shrink-0 transition-colors duration-300">
    <div class="mr-auto">
      <h1 class="text-sm font-semibold text-slate-800 dark:text-slate-100 leading-tight">Carga de Calificaciones</h1>
      <p class="text-[11px] text-slate-400 dark:text-slate-400 leading-tight">Evaluación por módulos y promedio final</p>
    </div>

    <div id="toast-msg" class="hidden" role="alert" aria-live="assertive"></div>
  </header>

  <main class="flex-1 p-6 flex flex-col gap-5 overflow-y-auto">

    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm p-4 flex flex-col sm:flex-row items-center gap-3 transition-colors duration-300">
      <div class="flex items-center gap-2.5 shrink-0">
        <div class="w-8 h-8 bg-blue-50 dark:bg-slate-700 rounded-lg flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-900 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </div>
        <label for="select-curso" class="text-sm font-semibold text-slate-700 dark:text-slate-200 whitespace-nowrap">
          Seleccionar Diplomado:
        </label>
      </div>

      <select
        id="select-curso"
        class="flex-1 w-full border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2.5 text-sm text-slate-700 dark:text-white bg-slate-50 dark:bg-slate-900 outline-none focus:border-blue-900 dark:focus:border-blue-500 focus:ring-2 focus:ring-blue-900/10 transition cursor-pointer"
      >
        <option value="" disabled selected class="text-slate-700 dark:text-white bg-white dark:bg-slate-800">— Elija un programa de la lista —</option>
        {diplomados.map((curso) => (
          <option value={curso.id} class="text-slate-700 dark:text-white bg-white dark:bg-slate-800">{curso.name}</option>
        ))}
      </select>
    </div>

    <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm overflow-hidden flex-1 transition-colors duration-300">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700">
            <tr class="text-[10px] font-bold text-slate-500 dark:text-slate-300 uppercase tracking-wider whitespace-nowrap">
              <th class="px-4 py-3 w-28">Cédula</th>
              <th class="px-4 py-3 min-w-[150px]">Estudiante</th>
              <th class="px-3 py-3 w-20 text-center">Mod 1</th>
              <th class="px-3 py-3 w-20 text-center">Mod 2</th>
              <th class="px-3 py-3 w-20 text-center">Mod 3</th>
              <th class="px-3 py-3 w-20 text-center">Mod 4</th>
              <th class="px-4 py-3 w-24 text-center bg-slate-100 dark:bg-slate-700/80">Nota Final</th>
              <th class="px-4 py-3 w-28 text-center">Estado</th>
              <th class="px-4 py-3 w-28 text-center">Acción</th>
            </tr>
          </thead>
          <tbody id="tabla-calificaciones" class="divide-y divide-slate-100 dark:divide-slate-700">
            <tr>
              <td colspan="9" class="py-20 text-center">
                <div class="flex flex-col items-center text-slate-300 dark:text-slate-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                  </svg>
                  <p class="text-sm font-medium text-slate-400 dark:text-slate-400">Seleccione un diplomado para cargar la lista</p>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-[11px] text-center text-slate-300 dark:text-slate-500">
      © {new Date().getFullYear()} Sistema de Gestión Académica — Escuela Nacional de los Derechos Humanos
    </p>
  </main>
</DashboardLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- CONSTANTES CENTRALIZADAS ---
    const API_BASE_URL = 'http://localhost:3000/api/enrollments';
    
    const getCookie = (name) => {
      const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
      return match ? match[2] : null;
    };
    
    const token = getCookie('token_sga');
    
    // --- REFERENCIAS AL DOM ---
    const selectCurso = document.getElementById('select-curso');
    const tabla = document.getElementById('tabla-calificaciones');
    const toast = document.getElementById('toast-msg');

    // --- HELPERS DE UI ---
    
    /**
     * Despliega un mensaje flotante temporal.
     * @param {string} mensaje - Texto a mostrar.
     * @param {'exito' | 'error'} tipo - Define la paleta de colores.
     */
    const mostrarToast = (mensaje, tipo) => {
      toast.textContent = mensaje;
      const clasesExito = 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-400 border border-green-200 dark:border-green-800/50';
      const clasesError = 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400 border border-red-200 dark:border-red-800/50';
      
      toast.className = `ml-auto px-4 py-2 rounded-lg text-sm font-semibold transition-opacity duration-300 ${ tipo === 'exito' ? clasesExito : clasesError }`;
      toast.classList.remove('hidden');
      
      setTimeout(() => { toast.classList.add('hidden'); }, 3000);
    };

    /**
     * Construye el HTML de una fila de la tabla para un estudiante.
     * @param {Object} est - Datos del estudiante.
     * @returns {string} HTML de la fila (tr).
     */
    const generarFilaEstudiante = (est) => {
      const notas = [est.grade1, est.grade2, est.grade3, est.grade4].map(g => (g != null ? g : ''));
      
      // Lógica de cálculo inicial
      const hayNotasCargadas = notas.some(g => g !== '');
      const promVal = notas.reduce((acc, curr) => acc + Number(curr || 0), 0) / 4;
      const notaFinal = hayNotasCargadas ? promVal.toFixed(1) : 0;
      
      // Lógica de estilos dinámicos
      let badgeColor = 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300 border-transparent';
      let estadoTexto = 'En curso';
      let colorFinal = 'text-slate-700 dark:text-slate-300';
      
      if (hayNotasCargadas) {
        if (promVal >= 10) {
          badgeColor = 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border-green-200 dark:border-green-800/50';
          estadoTexto = 'Aprobado';
          colorFinal = 'text-green-600 dark:text-green-400';
        } else {
          badgeColor = 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border-red-200 dark:border-red-800/50';
          estadoTexto = 'Reprobado';
          colorFinal = 'text-red-600 dark:text-red-400';
        }
      }

      const inputCls = "w-14 text-center border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 dark:text-white rounded-md px-1 py-1 outline-none focus:ring-2 focus:ring-blue-500 font-semibold text-sm transition-colors";

      return `
        <tr class="hover:bg-slate-50/80 dark:hover:bg-slate-700/50 transition-colors whitespace-nowrap">
          <td class="p-4 font-semibold text-slate-600 dark:text-slate-300 text-xs">V-${est.cedula}</td>
          <td class="p-4 text-slate-900 dark:text-slate-100 font-medium text-xs">${est.fullName}</td>
          
          ${notas.map((nota, i) => `
            <td class="p-3 text-center">
              <input type="number" id="m${i+1}-${est.enrollmentId}" min="0" max="20" value="${nota}" class="${inputCls}" oninput="recalcularPromedio(${est.enrollmentId})">
            </td>
          `).join('')}

          <td class="p-4 text-center bg-slate-50/50 dark:bg-slate-700/30">
            <span id="final-${est.enrollmentId}" class="font-bold text-base ${colorFinal}">${notaFinal}</span>
          </td>

          <td class="p-4 text-center">
            <span id="badge-${est.enrollmentId}" class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase transition-colors border ${badgeColor}">
              ${estadoTexto}
            </span>
          </td>

          <td class="p-4 text-center">
            <button 
              onclick="guardarNotas(${est.enrollmentId})"
              class="bg-blue-900 hover:bg-blue-800 dark:bg-blue-600 dark:hover:bg-blue-500 text-white font-semibold px-3 py-1.5 rounded text-xs transition shadow-sm active:scale-95"
            >
              Guardar
            </button>
          </td>
        </tr>
      `;
    };


    /**
     * Calcula dinámicamente el promedio y actualiza el DOM de forma local.
     * @param {number} id - Identificador de la inscripción.
     */
    window.recalcularPromedio = (id) => {
      const inputs = [1, 2, 3, 4].map(num => document.getElementById(`m${num}-${id}`));
      
      inputs.forEach(input => {
        if (input.value !== '') {
          let val = parseFloat(input.value);
          if (val > 20) input.value = 20;
          if (val < 0) input.value = 0;
        }
      });

      // Cálculo matemático
      const notas = inputs.map(input => parseFloat(input.value) || 0);
      const promedio = (notas.reduce((acc, val) => acc + val, 0) / 4).toFixed(1);
      
      // Actualización del DOM
      const notaFinalDisplay = document.getElementById(`final-${id}`);
      const badge = document.getElementById(`badge-${id}`);
      
      notaFinalDisplay.textContent = promedio;

      const estaAprobado = parseFloat(promedio) >= 10;
      
      notaFinalDisplay.className = `font-bold text-base ${estaAprobado ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400"}`;
      
      badge.className = `px-2.5 py-1 rounded-full text-[10px] font-bold uppercase transition-colors border ${
        estaAprobado 
          ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border-green-200 dark:border-green-800/50' 
          : 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400 border-red-200 dark:border-red-800/50'
      }`;
      badge.textContent = estaAprobado ? 'Aprobado' : 'Reprobado';
    };

    /**
     * Recopila las notas del DOM, valida y envía al backend.
     * @param {number} enrollmentId - Identificador de la inscripción.
     */
    window.guardarNotas = async (enrollmentId) => {
      const notas = [1, 2, 3, 4].map(num => document.getElementById(`m${num}-${enrollmentId}`).value);

      // Validación de seguridad
      const sonValidas = notas.every(val => val === '' || (parseFloat(val) >= 0 && parseFloat(val) <= 20));
      
      if (!sonValidas) {
         mostrarToast('⚠️ Las notas deben estar estrictamente entre 0 y 20.', 'error');
         return;
      }
   
      try {
        const payloadBody = {
          grade1: notas[0] !== '' ? parseFloat(notas[0]) : null,
          grade2: notas[1] !== '' ? parseFloat(notas[1]) : null,
          grade3: notas[2] !== '' ? parseFloat(notas[2]) : null,
          grade4: notas[3] !== '' ? parseFloat(notas[3]) : null
        };

        const res = await fetch(`${API_BASE_URL}/${enrollmentId}/grades`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json', 
            'Authorization': `Bearer ${token}` 
          },
          body: JSON.stringify(payloadBody)
        });
   
        if (res.ok) {
          mostrarToast('✅ Calificaciones guardadas con éxito.', 'exito');
        } else {
          const data = await res.json();
          mostrarToast(data.error || '❌ Error al guardar las notas.', 'error');
        }
      } catch (error) {
        mostrarToast('❌ Falla crítica de comunicación con el servidor.', 'error');
      }
    };
    
    // Carga la lista de estudiantes al seleccionar un diplomado
    selectCurso.addEventListener('change', async (e) => {
      const courseId = e.target.value;
      if (!courseId) return;
   
      tabla.innerHTML = `<tr><td colspan="9" class="p-8 text-center text-slate-400 dark:text-slate-500">Procesando registros académicos...</td></tr>`;
   
      try {
        const res = await fetch(`${API_BASE_URL}/course/${courseId}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!res.ok) throw new Error('Error HTTP');
        
        const estudiantes = await res.json();
   
        if (estudiantes.length === 0) {
          tabla.innerHTML = `<tr><td colspan="9" class="p-8 text-center text-orange-500 dark:text-orange-400 font-medium">No existen matriculaciones activas para este diplomado.</td></tr>`;
          return;
        }
   
        // Inyectar HTML generado por el helper
        tabla.innerHTML = estudiantes.map(generarFilaEstudiante).join('');
   
      } catch (error) {
        tabla.innerHTML = `<tr><td colspan="9" class="p-8 text-center text-red-500 dark:text-red-400">Error de red al establecer conexión con el backend.</td></tr>`;
      }
    });

  });
</script>